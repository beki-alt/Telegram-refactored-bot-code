# ── Copy to .env and fill in my values ────────────────────────────────────

# Telegram bot token (from @BotFather)
TELEGRAM_TOKEN=my-telegram-bot-token

# my Telegram user ID — becomes the super-admin
ADMIN_ID=123456789

# Numeric ID of the Telegram channel/group where receipt photos are forwarded.
# The bot must be an admin member of that channel.
# Previously named CHANNEL_ID; both names are accepted.
RECEIPT_CHANNEL_ID=-1001234567890

# Supabase project URL and anon/service-role key
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=my-supabase-anon-or-service-key

# Logging (optional — defaults shown)
LOG_LEVEL=INFO
LOG_FILE=./logs/bot.log

# Keep-alive server port (optional — default 8080)
PORT=8080
